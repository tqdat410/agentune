    "node-mpv": "^1.5.0",
    "ws": "^8.19.0",
    "youtube-dl-exec": "^3.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3"
  }
