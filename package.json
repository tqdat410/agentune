{
  "name": "sbotify",
  "version": "0.1.0",
  "description": "MCP music server — let your coding agent be your DJ",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sbotify": "dist/index.js"
  },
  "files": [
    "dist/",
    "public/"
  ],
  "scripts": {
    "build": "tsc",
